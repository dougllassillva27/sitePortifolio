@echo off
setlocal EnableExtensions

set "ARQUIVO_BASE64=%TEMP%\barberflow_neon_%RANDOM%.b64"
set "ARQUIVO_ZIP=%TEMP%\barberflow_neon_%RANDOM%.zip"
set "PASTA_DESTINO=%~dp0"

powershell -NoProfile -ExecutionPolicy Bypass -Command "$linhas = Get-Content -LiteralPath '%~f0'; $indice = [Array]::IndexOf($linhas, '__BARBERFLOW_NEON_ZIP_BASE64__'); if ($indice -lt 0) { throw 'Marcador Base64 nao encontrado.' }; $linhas[($indice + 1)..($linhas.Count - 1)] | Set-Content -LiteralPath '%ARQUIVO_BASE64%' -Encoding ASCII"

if errorlevel 1 (
  echo Erro ao extrair Base64 interno.
  exit /b 1
)

certutil -f -decode "%ARQUIVO_BASE64%" "%ARQUIVO_ZIP%" >nul

if errorlevel 1 (
  echo Erro ao decodificar ZIP interno.
  del "%ARQUIVO_BASE64%" >nul 2>&1
  exit /b 1
)

powershell -NoProfile -ExecutionPolicy Bypass -Command "Expand-Archive -LiteralPath '%ARQUIVO_ZIP%' -DestinationPath '%PASTA_DESTINO%' -Force"

if errorlevel 1 (
  echo Erro ao extrair projeto.
  del "%ARQUIVO_BASE64%" >nul 2>&1
  del "%ARQUIVO_ZIP%" >nul 2>&1
  exit /b 1
)

del "%ARQUIVO_BASE64%" >nul 2>&1
del "%ARQUIVO_ZIP%" >nul 2>&1

echo.
echo BarberFlow Neon criado com sucesso.
echo.
echo Proximos comandos:
echo cd barberflow-neon
echo npm install
echo npm run test
echo npm run build
echo.
echo Backend:
echo cd backend
echo python -m venv .venv
echo .venv\Scripts\activate
echo pip install -r requirements.txt
echo copy .env.example .env
echo python scripts\aplicar_migracoes.py
echo uvicorn app.main:app --reload
echo.
exit /b 0

